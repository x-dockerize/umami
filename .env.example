# -------------------------------------------------
# General
# -------------------------------------------------
# https://github.com/umami-software/umami/pkgs/container/umami
UMAMI_VERSION=3.0.3
UMAMI_SERVER_HOSTNAME=umami.example.com
TZ=Europe/Istanbul

# -------------------------------------------------
# Database
# -------------------------------------------------
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://umami:changeme@postgres:5432/umami

# -------------------------------------------------
# Security
# -------------------------------------------------
# Token signing secret. Generate: openssl rand -hex 32
# WARNING: Never change after first run — all sessions will be invalidated.
APP_SECRET=

# -------------------------------------------------
# Telemetry
# -------------------------------------------------
# Disable sending anonymous usage stats to umami.is
DISABLE_TELEMETRY=1

# -------------------------------------------------
# Tracker
# -------------------------------------------------
# Script path served to browsers. Change to avoid ad-blocker detection.
# Must start with /  (e.g. /analytics.js, /stats.js)
TRACKER_SCRIPT_NAME=/script.js
